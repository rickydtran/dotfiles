[include]
    path = ~/.gitconfig.inc
[user]
    name = Ricky Tran
    email = rickydtran@gmail.com
[includeIf "gitdir:~/sandbox/swxtchio/"]
    path = ~/sandbox/swxtchio/.gitconfig
[rerere]
    enabled = false
[column]
    ui = auto
[branch]
    sort = committerdate
[gpg]
    format = ssh
; machine-local: SSH signing key + commit.gpgsign=true (not in repo; absent => no signing)
[include]
    path = ~/.gitconfig.local
